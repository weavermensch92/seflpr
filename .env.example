# Database
POSTGRES_USER=selfpr
POSTGRES_PASSWORD=selfpr_secret
POSTGRES_DB=selfpr

# Redis
REDIS_PASSWORD=redis_secret

# JWT (RS256 - generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (AES-256-GCM) - 32 bytes hex
ENCRYPTION_KEY=your_32_byte_hex_key_here

# AI APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Search APIs
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Payment (Toss Payments)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# App
APP_ENV=development
SECRET_KEY=change_this_to_random_secret
CORS_ORIGINS=http://localhost:5173

# Superadmin seed (실제 값은 .env에만 기록, 절대 커밋 금지)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=
